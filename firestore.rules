rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isFamilyMember() {
      // IMPORTANT: Replace this placeholder list before deploying to production.
      return signedIn() && request.auth.token.email in [
        'jimmymcma@gmail.com',
        'jimmymcmahoncoding@gmail.com',
        'anna5_11@hotmail.com'
      ];
    }

    match /messages/{messageId} {
      allow read: if isFamilyMember();
      allow create: if isFamilyMember()
        && request.resource.data.keys().hasOnly(['text', 'uid', 'displayName', 'createdAt'])
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 500
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }
  }
}
