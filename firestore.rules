rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isAllowed() {
      return signedIn() &&
        exists(/databases/$(database)/documents/allowedUsers/$(userEmail()));
    }

    function isAdmin() {
      return isAllowed() &&
        get(/databases/$(database)/documents/allowedUsers/$(userEmail())).data.isAdmin == true;
    }

    match /allowedUsers/{email} {
      allow read: if isAllowed();
      allow write: if isAdmin();
    }

    match /pendingUsers/{email} {
      allow create: if signedIn()
        && userEmail() == email
        && !exists(/databases/$(database)/documents/allowedUsers/$(email))
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'requestedAt'])
        && request.resource.data.email is string
        && request.resource.data.email == email
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 50
        && request.resource.data.requestedAt == request.time;
      allow read, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAllowed();
      allow create: if isAllowed()
          && request.resource.data.keys().hasOnly(['text', 'uid', 'displayName', 'createdAt', 'type', 'gifUrl', 'sticker', 'avatar', 'avatarUrl', 'replyTo', 'audioUrl', 'duration', 'photoUrl', 'photoUrls', 'mentions', 'question', 'options', 'votes'])
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.displayName is string
        && request.resource.data.createdAt == request.time
        && (!('avatar' in request.resource.data) || (request.resource.data.avatar is string && request.resource.data.avatar.size() <= 10))
        && (!('avatarUrl' in request.resource.data) || (request.resource.data.avatarUrl is string && request.resource.data.avatarUrl.size() <= 1024))
        && (!('replyTo' in request.resource.data) || (
          request.resource.data.replyTo is map
          && request.resource.data.replyTo.keys().hasOnly(['text', 'displayName', 'messageId'])
          && request.resource.data.replyTo.text is string
          && request.resource.data.replyTo.text.size() <= 500
          && request.resource.data.replyTo.displayName is string
          && request.resource.data.replyTo.displayName.size() <= 50
          && (!('messageId' in request.resource.data.replyTo) || request.resource.data.replyTo.messageId is string)
        ))
        && (
          (
            !('type' in request.resource.data)
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 500
          )
          ||
          (
            request.resource.data.type == 'gif'
            && request.resource.data.gifUrl is string
            && request.resource.data.gifUrl.size() > 0
            && request.resource.data.text == '[GIF]'
          )
          ||
          (
            request.resource.data.type == 'sticker'
            && request.resource.data.sticker is string
            && request.resource.data.sticker.size() > 0
            && request.resource.data.sticker.size() <= 10
            && request.resource.data.text == '[Sticker]'
          )
          ||
          (
            request.resource.data.type == 'voice'
            && request.resource.data.audioUrl is string
            && request.resource.data.audioUrl.size() > 0
            && request.resource.data.audioUrl.size() <= 1024
            && request.resource.data.duration is number
            && request.resource.data.duration >= 0
            && request.resource.data.duration <= 300
            && request.resource.data.text == '[Voice message]'
          )
          ||
          (
            request.resource.data.type == 'photo'
            && request.resource.data.photoUrl is string
            && request.resource.data.photoUrl.size() > 0
            && request.resource.data.photoUrl.size() <= 1024
            && request.resource.data.text == '[Photo]'
          )
          ||
          (
            request.resource.data.type == 'photos'
            && request.resource.data.photoUrls is list
            && request.resource.data.photoUrls.size() > 0
            && request.resource.data.photoUrls.size() <= 10
            && request.resource.data.text == '[Photos]'
          )
          ||
          (
            request.resource.data.type == 'poll'
            && request.resource.data.question is string
            && request.resource.data.question.size() > 0
            && request.resource.data.question.size() <= 200
            && request.resource.data.options is list
            && request.resource.data.options.size() >= 2
            && request.resource.data.options.size() <= 4
            && request.resource.data.votes is map
            && request.resource.data.text == '[Poll]'
          )
        )
        && (!('mentions' in request.resource.data) || (
          request.resource.data.mentions is list
          && request.resource.data.mentions.size() <= 20
        ));
      allow delete: if isAllowed() && resource.data.uid == request.auth.uid;
      allow update: if isAllowed()
        && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'seenBy', 'votes'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactions'])
              || request.resource.data.reactions is map
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['seenBy'])
              || (
                request.resource.data.seenBy is map
                && request.resource.data.seenBy.diff(resource.data.get('seenBy', {})).affectedKeys().hasOnly([request.auth.uid])
              )
            )
          )
          ||
          (
            resource.data.uid == request.auth.uid
            && resource.data.get('type', null) == null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 500
            && request.resource.data.editedAt == request.time
          )
        );
    }

    match /userProfiles/{userId} {
      allow read: if isAllowed();
      allow write: if isAllowed()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['avatar', 'displayName', 'avatarUrl'])
        && request.resource.data.avatar is string
        && request.resource.data.avatar.size() <= 10
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 30
        && (!('avatarUrl' in request.resource.data) || (request.resource.data.avatarUrl is string && request.resource.data.avatarUrl.size() <= 1024));
    }

    match /fcmTokens/{userId} {
      allow read: if false;
      allow write: if isAllowed()
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['token', 'updatedAt'])
        && request.resource.data.token is string
        && request.resource.data.token.size() > 0
        && request.resource.data.token.size() <= 4096
        && request.resource.data.updatedAt == request.time;
      allow delete: if isAllowed() && request.auth.uid == userId;
    }

    match /presence/{userId} {
      allow read: if isAllowed();
      allow write: if isAllowed()
        && request.auth.uid == userId
        && request.resource.data.online is bool
        && request.resource.data.lastSeen == request.time
        && request.resource.data.keys().hasOnly(['online', 'lastSeen', 'displayName', 'avatar'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 30
        && request.resource.data.avatar is string
        && request.resource.data.avatar.size() <= 10;
    }

    match /typingIndicators/{userId} {
      allow read: if isAllowed();
      allow write: if isAllowed()
        && request.auth.uid == userId
        && request.resource.data.isTyping is bool
        && request.resource.data.updatedAt == request.time
        && request.resource.data.roomId is string
        && request.resource.data.roomId.size() <= 200
        && request.resource.data.keys().hasOnly(['isTyping', 'displayName', 'roomId', 'updatedAt'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() <= 30;
      allow delete: if isAllowed() && request.auth.uid == userId;
    }

    match /directMessages/{conversationId} {
      allow read: if isAllowed()
        && (resource == null || request.auth.uid in resource.data.participants);
      allow create: if isAllowed()
        && request.resource.data.keys().hasOnly(['participants', 'updatedAt', 'lastMessage'])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.updatedAt == request.time
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 100;
      allow update: if isAllowed()
        && request.auth.uid in resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updatedAt', 'lastMessage'])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.lastMessage is string
        && request.resource.data.lastMessage.size() <= 100;

      match /messages/{messageId} {
        function convParticipants() {
          return get(/databases/$(database)/documents/directMessages/$(conversationId)).data.participants;
        }
        allow read: if isAllowed()
          && request.auth.uid in convParticipants();
        allow create: if isAllowed()
          && request.auth.uid in convParticipants()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.createdAt == request.time
          && request.resource.data.keys().hasOnly(['text', 'uid', 'displayName', 'avatar', 'avatarUrl', 'createdAt', 'type', 'gifUrl', 'sticker', 'audioUrl', 'duration', 'photoUrl', 'photoUrls', 'replyTo'])
          && request.resource.data.displayName is string
          && request.resource.data.displayName.size() <= 50
          && (!('avatar' in request.resource.data) || (request.resource.data.avatar is string && request.resource.data.avatar.size() <= 10))
          && (!('avatarUrl' in request.resource.data) || (request.resource.data.avatarUrl is string && request.resource.data.avatarUrl.size() <= 1024))
          && (!('replyTo' in request.resource.data) || (
            request.resource.data.replyTo is map
            && request.resource.data.replyTo.keys().hasOnly(['text', 'displayName', 'messageId'])
            && request.resource.data.replyTo.text is string
            && request.resource.data.replyTo.text.size() <= 500
            && request.resource.data.replyTo.displayName is string
            && request.resource.data.replyTo.displayName.size() <= 50
            && (!('messageId' in request.resource.data.replyTo) || request.resource.data.replyTo.messageId is string)
          ))
          && (
            (
              !('type' in request.resource.data)
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 500
            )
            ||
            (
              request.resource.data.type == 'gif'
              && request.resource.data.gifUrl is string
              && request.resource.data.gifUrl.size() > 0
              && request.resource.data.text == '[GIF]'
            )
            ||
            (
              request.resource.data.type == 'sticker'
              && request.resource.data.sticker is string
              && request.resource.data.sticker.size() > 0
              && request.resource.data.sticker.size() <= 10
              && request.resource.data.text == '[Sticker]'
            )
            ||
            (
              request.resource.data.type == 'voice'
              && request.resource.data.audioUrl is string
              && request.resource.data.audioUrl.size() > 0
              && request.resource.data.audioUrl.size() <= 1024
              && request.resource.data.duration is number
              && request.resource.data.duration >= 0
              && request.resource.data.duration <= 300
              && request.resource.data.text == '[Voice message]'
            )
            ||
            (
              request.resource.data.type == 'photo'
              && request.resource.data.photoUrl is string
              && request.resource.data.photoUrl.size() > 0
              && request.resource.data.photoUrl.size() <= 1024
              && request.resource.data.text == '[Photo]'
            )
            ||
            (
              request.resource.data.type == 'photos'
              && request.resource.data.photoUrls is list
              && request.resource.data.photoUrls.size() > 0
              && request.resource.data.photoUrls.size() <= 10
              && request.resource.data.text == '[Photos]'
            )
          );
        allow update: if isAllowed()
          && request.auth.uid in convParticipants()
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
            ||
            (
              resource.data.uid == request.auth.uid
              && resource.data.get('type', null) == null
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt'])
              && request.resource.data.text is string
              && request.resource.data.text.size() > 0
              && request.resource.data.text.size() <= 500
              && request.resource.data.editedAt == request.time
            )
          );
        allow delete: if isAllowed()
          && resource.data.uid == request.auth.uid;
      }
    }
  }
}
